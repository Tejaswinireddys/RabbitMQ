{
  "dashboard": {
    "id": null,
    "title": "RabbitMQ - Cluster Health Dashboard",
    "tags": ["rabbitmq", "cluster", "health", "nodes"],
    "style": "dark",
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Cluster Node Status",
        "type": "stat",
        "targets": [
          {
            "expr": "rabbitmq_node_is_running",
            "legendFormat": "{{node}} - Running",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "green", "value": 1}
              ]
            },
            "unit": "short",
            "min": 0,
            "max": 1
          }
        },
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto",
          "orientation": "auto",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "textMode": "auto"
        }
      },
      {
        "id": 2,
        "title": "Cluster Partition Status",
        "type": "stat",
        "targets": [
          {
            "expr": "rabbitmq_cluster_partitions",
            "legendFormat": "Partitions",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "red", "value": 1}
              ]
            },
            "unit": "short",
            "min": 0
          }
        },
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto",
          "orientation": "auto",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "textMode": "auto"
        }
      },
      {
        "id": 3,
        "title": "Total Cluster Nodes",
        "type": "stat",
        "targets": [
          {
            "expr": "count(rabbitmq_node_is_running)",
            "legendFormat": "Total Nodes",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 1},
                {"color": "green", "value": 3}
              ]
            },
            "unit": "short",
            "min": 0
          }
        },
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 8},
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto",
          "orientation": "auto",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "textMode": "auto"
        }
      },
      {
        "id": 4,
        "title": "Running Nodes",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(rabbitmq_node_is_running)",
            "legendFormat": "Running Nodes",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 1},
                {"color": "green", "value": 3}
              ]
            },
            "unit": "short",
            "min": 0
          }
        },
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 8},
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto",
          "orientation": "auto",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "textMode": "auto"
        }
      },
      {
        "id": 5,
        "title": "Cluster Health Score",
        "type": "gauge",
        "targets": [
          {
            "expr": "sum(rabbitmq_node_is_running) / count(rabbitmq_node_is_running) * 100",
            "legendFormat": "Cluster Health %",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 50},
                {"color": "green", "value": 100}
              ]
            },
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        },
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 8},
        "options": {
          "orientation": "auto",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "showThresholdLabels": false,
          "showThresholdMarkers": true
        }
      },
      {
        "id": 6,
        "title": "Node Memory Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rabbitmq_node_mem_used / rabbitmq_node_mem_limit * 100",
            "legendFormat": "{{node}} - Memory %",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette"},
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "barAlignment": 0,
              "lineWidth": 2,
              "fillOpacity": 10,
              "gradientMode": "none",
              "spanNulls": false,
              "showPoints": "never",
              "pointSize": 5,
              "stacking": {"mode": "none", "group": "A"},
              "axisLabel": "Memory %",
              "scaleDistribution": {"type": "linear"},
              "hideFrom": {"legend": false, "tooltip": false, "vis": false},
              "thresholdsStyle": {"mode": "off"}
            },
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
        "options": {
          "legend": {
            "calcs": ["last", "max", "mean"],
            "displayMode": "table",
            "placement": "right"
          },
          "tooltip": {
            "mode": "multi",
            "sort": "desc"
          }
        }
      },
      {
        "id": 7,
        "title": "Node Disk Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rabbitmq_node_disk_free / rabbitmq_node_disk_free_limit * 100",
            "legendFormat": "{{node}} - Disk Free %",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette"},
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "barAlignment": 0,
              "lineWidth": 2,
              "fillOpacity": 10,
              "gradientMode": "none",
              "spanNulls": false,
              "showPoints": "never",
              "pointSize": 5,
              "stacking": {"mode": "none", "group": "A"},
              "axisLabel": "Disk Free %",
              "scaleDistribution": {"type": "linear"},
              "hideFrom": {"legend": false, "tooltip": false, "vis": false},
              "thresholdsStyle": {"mode": "off"}
            },
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "options": {
          "legend": {
            "calcs": ["last", "max", "mean"],
            "displayMode": "table",
            "placement": "right"
          },
          "tooltip": {
            "mode": "multi",
            "sort": "desc"
          }
        }
      },
      {
        "id": 8,
        "title": "Node Process Count",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rabbitmq_node_processes",
            "legendFormat": "{{node}} - Processes",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette"},
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "barAlignment": 0,
              "lineWidth": 2,
              "fillOpacity": 10,
              "gradientMode": "none",
              "spanNulls": false,
              "showPoints": "never",
              "pointSize": 5,
              "stacking": {"mode": "none", "group": "A"},
              "axisLabel": "Processes",
              "scaleDistribution": {"type": "linear"},
              "hideFrom": {"legend": false, "tooltip": false, "vis": false},
              "thresholdsStyle": {"mode": "off"}
            },
            "unit": "short"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
        "options": {
          "legend": {
            "calcs": ["last", "max", "mean"],
            "displayMode": "table",
            "placement": "right"
          },
          "tooltip": {
            "mode": "multi",
            "sort": "desc"
          }
        }
      },
      {
        "id": 9,
        "title": "Node File Descriptor Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rabbitmq_node_fd_used / rabbitmq_node_fd_total * 100",
            "legendFormat": "{{node}} - FD Usage %",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette"},
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "barAlignment": 0,
              "lineWidth": 2,
              "fillOpacity": 10,
              "gradientMode": "none",
              "spanNulls": false,
              "showPoints": "never",
              "pointSize": 5,
              "stacking": {"mode": "none", "group": "A"},
              "axisLabel": "FD Usage %",
              "scaleDistribution": {"type": "linear"},
              "hideFrom": {"legend": false, "tooltip": false, "vis": false},
              "thresholdsStyle": {"mode": "off"}
            },
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
        "options": {
          "legend": {
            "calcs": ["last", "max", "mean"],
            "displayMode": "table",
            "placement": "right"
          },
          "tooltip": {
            "mode": "multi",
            "sort": "desc"
          }
        }
      },
      {
        "id": 10,
        "title": "Cluster Node Summary",
        "type": "table",
        "targets": [
          {
            "expr": "rabbitmq_node_is_running",
            "format": "table",
            "instant": true,
            "refId": "A"
          },
          {
            "expr": "rabbitmq_node_mem_used / rabbitmq_node_mem_limit * 100",
            "format": "table",
            "instant": true,
            "refId": "B"
          },
          {
            "expr": "rabbitmq_node_disk_free / rabbitmq_node_disk_free_limit * 100",
            "format": "table",
            "instant": true,
            "refId": "C"
          },
          {
            "expr": "rabbitmq_node_processes",
            "format": "table",
            "instant": true,
            "refId": "D"
          },
          {
            "expr": "rabbitmq_node_fd_used / rabbitmq_node_fd_total * 100",
            "format": "table",
            "instant": true,
            "refId": "E"
          },
          {
            "expr": "rabbitmq_connections_total",
            "format": "table",
            "instant": true,
            "refId": "F"
          },
          {
            "expr": "rabbitmq_channels_total",
            "format": "table",
            "instant": true,
            "refId": "G"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "align": "auto",
              "displayMode": "auto"
            }
          }
        },
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 28},
        "options": {
          "showHeader": true,
          "sortBy": [
            {
              "desc": true,
              "displayName": "Running"
            }
          ]
        }
      }
    ]
  }
}
