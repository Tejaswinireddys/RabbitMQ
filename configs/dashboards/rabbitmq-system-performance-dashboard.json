          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 10000},
                {"color": "orange", "value": 20000},
                {"color": "red", "value": 50000}
              ]
            },
            "unit": "short",
            "min": 0
