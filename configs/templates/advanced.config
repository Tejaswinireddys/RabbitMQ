%% RabbitMQ Advanced Configuration
%% This file contains advanced Erlang configuration for RabbitMQ 4.x

[
  %% Enable Prometheus metrics
  {rabbitmq_prometheus, [
    {path, "/metrics"},
    {registry, default}
  ]},

  %% Enable federation plugin
  {rabbitmq_federation, [
    {upstream_set, federated_servers}
  ]},

  %% Enable shovel plugin
  {rabbitmq_shovel, [
    {shovels, []}
  ]},

  %% Enable consistent hash exchange
  {rabbitmq_consistent_hash_exchange, []},

  %% Enable LDAP authentication backend
  {rabbitmq_auth_backend_ldap, [
    {servers, ["ldap://ldap.company.com"]},
    {user_dn_pattern, "uid=${username},ou=users,dc=company,dc=com"},
    {use_start_tls, false},
    {port, 389},
    {timeout, 10000}
  ]},

  %% Kernel configuration for better performance
  {kernel, [
    {inet_dist_listen_min, 25672},
    {inet_dist_listen_max, 25672},
    {net_ticktime, 60}
  ]},

  %% SASL configuration for logging
  {sasl, [
    {sasl_error_logger, {file, "/var/log/rabbitmq/sasl.log"}},
    {errlog_type, error},
    {error_logger_mf_dir, "/var/log/rabbitmq/"},
    {error_logger_mf_maxbytes, 10485760},
    {error_logger_mf_maxfiles, 5}
  ]},

  %% OS_MON configuration for system monitoring
  {os_mon, [
    {start_disksup, true},
    {start_memsup, true},
    {start_cpu_sup, true}
  ]}
].