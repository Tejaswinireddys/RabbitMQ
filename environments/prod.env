# RabbitMQ Production Environment Configuration
# Sources base configuration and overrides with production-specific settings

# === Environment Info ===
ENVIRONMENT_NAME="production"
ENVIRONMENT_TYPE="production"

# === Cluster Name (Environment Specific) ===
RABBITMQ_CLUSTER_NAME="rabbitmq-production-cluster"

# === Node Configuration ===
RABBITMQ_NODE_1_HOSTNAME="prod-rmq-node1"
RABBITMQ_NODE_2_HOSTNAME="prod-rmq-node2"
RABBITMQ_NODE_3_HOSTNAME="prod-rmq-node3"

# === IP Addresses (Update with actual production environment IPs) ===
RABBITMQ_NODE_1_IP="10.30.30.10"
RABBITMQ_NODE_2_IP="10.30.30.11"
RABBITMQ_NODE_3_IP="10.30.30.12"

# === Load Balancer Configuration ===
RABBITMQ_VIP="10.30.30.100"
HAPROXY_HOST="10.30.30.101"

# === Security Overrides (Production-specific passwords) ===
RABBITMQ_DEFAULT_PASS="ProdAdmin@2024!"
RABBITMQ_CUSTOM_USER_1_PASS="ProdTeja@2024!"
RABBITMQ_CUSTOM_USER_2_PASS="ProdAswini@2024!"

# === SSL Certificate Paths ===
RABBITMQ_SSL_CACERT="$RABBITMQ_SSL_CERT_DIR/production/ca_certificate.pem"
RABBITMQ_SSL_CERT="$RABBITMQ_SSL_CERT_DIR/production/server_certificate.pem"
RABBITMQ_SSL_KEY="$RABBITMQ_SSL_CERT_DIR/production/server_key.pem"

# === Environment-specific Performance Settings ===
RABBITMQ_VM_MEMORY_HIGH_WATERMARK="0.7"
RABBITMQ_DISK_FREE_LIMIT="5GB"

# === Production-specific Monitoring ===
PROMETHEUS_PUSHGATEWAY="http://prod-prometheus-pushgateway:9091"
GRAFANA_URL="http://prod-grafana:3000"

# === Email Alerting for Production ===
EMAIL_ALERTS="prod-team@company.com,rabbitmq-alerts@company.com,oncall@company.com"
SLACK_WEBHOOK="https://hooks.slack.com/services/YOUR/PRODUCTION/WEBHOOK"

# === Production Database/External Dependencies ===
EXTERNAL_DB_HOST="prod-db.company.com"
EXTERNAL_API_ENDPOINT="https://prod-api.company.com"

# === Node-specific Configuration ===
# Node 1 (Primary in Production)
RABBITMQ_NODE_1_DISK_FREE_LIMIT="5GB"
RABBITMQ_NODE_1_MEMORY_LIMIT="8GB"

# Node 2 (Secondary)
RABBITMQ_NODE_2_DISK_FREE_LIMIT="5GB"
RABBITMQ_NODE_2_MEMORY_LIMIT="8GB"

# Node 3 (Secondary)
RABBITMQ_NODE_3_DISK_FREE_LIMIT="5GB"
RABBITMQ_NODE_3_MEMORY_LIMIT="8GB"

# === Environment-specific Features ===
RABBITMQ_ENABLE_FEATURE_FLAGS="stable_only"
RABBITMQ_DEBUG_MODE="false"

# === Backup Configuration for Production ===
RABBITMQ_BACKUP_RETENTION_DAYS="30"
RABBITMQ_BACKUP_SCHEDULE="0 0 * * *"  # Daily at midnight

# === Production Auto-Recovery Settings ===
RABBITMQ_FORCE_BOOT_ON_STARTUP="false"  # Conservative recovery for production
RABBITMQ_AUTO_RECOVERY_DELAY="60"       # Longer recovery delay for production
RABBITMQ_STARTUP_TIMEOUT="600"          # 10 minutes for production startup

# === Production Monitor Settings ===
RABBITMQ_MONITOR_CHECK_INTERVAL="120"   # Less frequent checks for production
RABBITMQ_MONITOR_RECOVERY_TIMEOUT="600" # Longer recovery timeout for production
RABBITMQ_MONITOR_MAX_FAILURES="5"       # Higher failure threshold for production
RABBITMQ_MONITOR_RECOVERY_COOLDOWN="3600" # 1 hour between attempts

# === Production Security Enhancements ===
RABBITMQ_SSL_VERIFY="verify_peer"
RABBITMQ_SSL_FAIL_IF_NO_PEER_CERT="true"
RABBITMQ_LOG_LEVEL="warning"  # Less verbose logging for production
