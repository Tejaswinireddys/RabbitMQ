%% =============================================================================
%% RabbitMQ Advanced Configuration (Erlang Term Format)
%% For settings not available in rabbitmq.conf
%% =============================================================================

[
  %% Kernel settings for networking
  {kernel, [
    %% Increase network buffer sizes for high throughput
    {inet_default_connect_options, [{nodelay, true}]},
    {inet_default_listen_options, [{nodelay, true}]}
  ]},

  %% RabbitMQ specific advanced settings
  {rabbit, [
    %% Cluster formation timeout (milliseconds)
    {cluster_formation, [
      {randomized_startup_delay_range, {5, 60}}
    ]},

    %% Mnesia table loading timeout for large datasets
    {mnesia_table_loading_retry_timeout, 30000},
    {mnesia_table_loading_retry_limit, 10},

    %% Lazy queue v2 settings (memory optimization)
    {lazy_queue_explicit_gc_run_operation_threshold, 1000},

    %% TCP buffer sizes tuning
    {tcp_listen_options, [
      {backlog, 4096},
      {nodelay, true},
      {linger, {true, 0}},
      {exit_on_close, false},
      {sndbuf, 196608},
      {recbuf, 196608}
    ]},

    %% Channel operation timeout
    {channel_operation_timeout, 60000}
  ]},

  %% Management plugin specific settings
  {rabbitmq_management, [
    %% HTTP request timeout
    {http_request_timeout, 60000},

    %% Path prefix for reverse proxy setups
    %% {path_prefix, "/rabbitmq"},

    %% Content security policy
    {content_security_policy, "default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'"}
  ]},

  %% Prometheus plugin settings
  {rabbitmq_prometheus, [
    {return_per_object_metrics, true}
  ]},

  %% AMQP 1.0 plugin (if using AMQP 1.0 clients)
  %% {rabbitmq_amqp1_0, [
  %%   {default_user, <<"guest">>},
  %%   {protocol_strict_mode, false}
  %% ]},

  %% Shovel plugin settings
  {rabbitmq_shovel, [
    {defaults, [
      {prefetch_count, 1000},
      {ack_mode, on_confirm},
      {reconnect_delay, 5}
    ]}
  ]}
].
